{
  "boundary_name": "Physical Boot Validation",
  "version": "1.0",
  "safety_rules": {
    "no_host_disk_modification": true,
    "no_bootloader_install_on_host_disks": true,
    "no_internal_drive_mounting_by_default": true,
    "no_os_core_runtime_mutation": true,
    "persistent_writes_must_target_TOWER_DATA_only": true
  },
  "boot_policy": {
    "source": "removable_media",
    "required_signals": [
      "kernel_init",
      "launcher_init",
      "persistence_mount_success"
    ],
    "reboot_validation_required": true
  }
}

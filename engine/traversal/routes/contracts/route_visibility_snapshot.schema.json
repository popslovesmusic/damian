{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "route_id": {
      "type": "string"
    },
    "visibility_level": {
      "type": "string",
      "enum": ["none", "low", "medium", "high"]
    },
    "environmental_cues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confirmed_hazards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["route_id", "visibility_level", "environmental_cues", "confirmed_hazards"]
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DomainRecord",
  "type": "object",
  "required": [
    "floor_id",
    "owner_id",
    "stability_level",
    "total_shards_invested",
    "upkeep_cost",
    "protection_flags",
    "bounded_flags_clean"
  ],
  "properties": {
    "floor_id": { "type": "integer" },
    "owner_id": { "type": "string" },
    "stability_level": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "total_shards_invested": { "type": "integer", "minimum": 0 },
    "upkeep_cost": {
      "type": "object",
      "required": ["shards_per_run"],
      "properties": {
        "shards_per_run": { "type": "integer", "minimum": 0 }
      }
    },
    "protection_flags": {
      "type": "object",
      "required": ["mutation_mitigation", "recovery_boost"],
      "properties": {
        "mutation_mitigation": { "type": "boolean" },
        "recovery_boost": { "type": "boolean" }
      }
    },
    "bounded_flags_clean": { "type": "boolean", "const": true }
  }
}

{
  "boundary_name": "Faction Schism",
  "version": "1.0",
  "safety_rules": {
    "no_permanent_player_government": true,
    "no_irreversible_social_exile": true,
    "no_global_political_authority": true,
    "no_admin_created_ideology": true,
    "no_forced_player_alignment": true,
    "no_save_deletion_from_politics": true,
    "no_unbounded_betrayal_loops": true,
    "schisms_must_be_bounded_and_auditable": true
  },
  "recovery_policy": {
    "political_recovery_must_be_possible": true,
    "splinter_groups_must_preserve_recoverability": true,
    "ideological_residue_must_be_contextual": true
  }
}

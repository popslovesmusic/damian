{
  "type": "object",
  "required": [
    "domain_state_id",
    "owner_player_id",
    "content_pack_id",
    "domain_archetype",
    "conquered",
    "dashboard_unlocked",
    "domain_level",
    "stability",
    "deviation",
    "active_modifiers",
    "operational_costs",
    "invasion_history",
    "forbidden_flags"
  ],
  "properties": {
    "domain_state_id": { "type": "string" },
    "owner_player_id": { "type": "string" },
    "content_pack_id": { "type": "string" },
    "domain_archetype": { "type": "string" },
    "conquered": { "type": "boolean" },
    "dashboard_unlocked": { "type": "boolean" },
    "domain_level": { "type": "integer", "minimum": 1 },
    "stability": { "type": "number", "minimum": 0, "maximum": 1 },
    "deviation": { "type": "number" },
    "active_modifiers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "operational_costs": {
      "type": "object",
      "required": ["maintenance", "mutation_control", "hazard_upkeep", "resource_transport"],
      "properties": {
        "maintenance": { "type": "integer", "minimum": 0 },
        "mutation_control": { "type": "integer", "minimum": 0 },
        "hazard_upkeep": { "type": "integer", "minimum": 0 },
        "resource_transport": { "type": "integer", "minimum": 0 }
      }
    },
    "invasion_history": {
      "type": "array",
      "items": { "type": "object" }
    },
    "forbidden_flags": {
      "type": "object",
      "required": ["playability_failure", "owner_immunity", "impossible_layout"],
      "properties": {
        "playability_failure": { "type": "boolean" },
        "owner_immunity": { "type": "boolean" },
        "impossible_layout": { "type": "boolean" }
      }
    }
  }
}

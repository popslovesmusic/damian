{
  "type": "object",
  "required": [
    "player_id",
    "profile_id",
    "content_pack_id",
    "level",
    "highest_floor_reached",
    "stats",
    "unlocked_skills",
    "equipped_items",
    "residue_pressure",
    "forbidden_flags"
  ],
  "properties": {
    "player_id": { "type": "string" },
    "profile_id": { "type": "string" },
    "content_pack_id": { "type": "string" },
    "level": { "type": "integer", "minimum": 1 },
    "highest_floor_reached": { "type": "integer", "minimum": 1 },
    "stats": {
      "type": "object",
      "required": ["health", "damage", "defense", "speed", "recovery"],
      "properties": {
        "health": { "type": "number", "minimum": 0 },
        "damage": { "type": "number", "minimum": 0 },
        "defense": { "type": "number", "minimum": 0 },
        "speed": { "type": "number", "minimum": 0 },
        "recovery": { "type": "number", "minimum": 0 }
      }
    },
    "unlocked_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "equipped_items": {
      "type": "array",
      "items": { "type": "string" }
    },
    "residue_pressure": {
      "type": "object",
      "required": ["dominant_build_visibility", "power_use_strain", "overoptimization_pressure"],
      "properties": {
        "dominant_build_visibility": { "type": "number" },
        "power_use_strain": { "type": "number" },
        "overoptimization_pressure": { "type": "number" }
      }
    },
    "forbidden_flags": {
      "type": "object",
      "required": ["permanent_invulnerability", "infinite_damage_scaling", "residue_immunity", "death_consequence_immunity"],
      "properties": {
        "permanent_invulnerability": { "type": "boolean" },
        "infinite_damage_scaling": { "type": "boolean" },
        "residue_immunity": { "type": "boolean" },
        "death_consequence_immunity": { "type": "boolean" }
      }
    }
  }
}

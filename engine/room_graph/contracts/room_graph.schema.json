{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Room Graph Contract",
  "type": "object",
  "properties": {
    "graph_id": { "type": "string" },
    "floor_id": { "type": "integer" },
    "domain_archetype": { "type": "string" },
    "layout_seed": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": { "$ref": "room_node.schema.json" }
    },
    "entry_node_id": { "type": "string" },
    "exit_node_id": { "type": "string" },
    "mutation_level": {
      "type": "integer",
      "minimum": 0
    },
    "identity_preserved": { "type": "boolean" },
    "playability_preserved": { "type": "boolean" },
    "survivor_mark_nodes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "graph_id",
    "floor_id",
    "domain_archetype",
    "layout_seed",
    "nodes",
    "entry_node_id",
    "exit_node_id",
    "mutation_level",
    "identity_preserved",
    "playability_preserved",
    "survivor_mark_nodes"
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EquipmentItem",
  "type": "object",
  "required": [
    "equipment_item_id",
    "item_name",
    "category_id",
    "rarity",
    "durability",
    "operational_profile",
    "bounded_flags"
  ],
  "properties": {
    "equipment_item_id": { "type": "string" },
    "item_name": { "type": "string" },
    "category_id": { "type": "string" },
    "rarity": {
      "enum": ["common", "uncommon", "rare", "mutation_touched"]
    },
    "durability": {
      "type": "object",
      "required": ["current", "maximum"],
      "properties": {
        "current": { "type": "number", "minimum": 0 },
        "maximum": { "type": "number", "minimum": 1 }
      }
    },
    "operational_profile": {
      "type": "object",
      "required": [
        "repair_pressure",
        "residue_visibility",
        "mutation_affinity",
        "capacity_pressure",
        "risk_profile"
      ],
      "properties": {
        "repair_pressure": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "residue_visibility": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "mutation_affinity": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "capacity_pressure": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "risk_profile": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "bounded_flags": {
      "type": "object",
      "required": [
        "grants_invulnerability",
        "grants_infinite_scaling",
        "bypasses_residue",
        "bypasses_defeat"
      ],
      "properties": {
        "grants_invulnerability": { "const": false },
        "grants_infinite_scaling": { "const": false },
        "bypasses_residue": { "const": false },
        "bypasses_defeat": { "const": false }
      }
    }
  }
}

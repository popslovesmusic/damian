{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InventoryItem",
  "type": "object",
  "required": ["item_id", "quantity"],
  "properties": {
    "item_id": { "type": "string" },
    "quantity": { "type": "integer", "minimum": 0 },
    "capacity_cost": { "type": "integer", "minimum": 0 },
    "metadata": { "type": "object" }
  }
}

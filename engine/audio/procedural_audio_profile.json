{
  "profile_id": "procedural-audio-v1",
  "version": "1.0",
  "rules": {
    "ambient_volume_scalar": {
      "base_value": 0.5,
      "pressure_modifier": {
        "pressure_low": 0.1,
        "pressure_medium": 0.5,
        "pressure_high": 1.0
      },
      "description": "Ambient volume scales with pressure."
    },
    "heartbeat_threshold": {
      "health_percentage": 20,
      "audio_event": "SURVIVAL_STRESS_HEARTBEAT",
      "description": "Heartbeat sound plays when health is below 20%."
    },
    "enemy_proximity_fade_distance": {
      "distance_units": 5,
      "audio_event": "ENEMY_PROXIMITY_GROWL",
      "description": "Growl fades in as enemy gets closer than 5 units."
    },
    "pressure_escalation_feedback": {
      "pressure_threshold": 60,
      "audio_event": "PRESSURE_ESCALATION_EFFECT",
      "description": "Subtle rising tension effect when pressure exceeds 60."
    }
  },
  "bounded_flags": {
    "placeholder_only": true,
    "debug_output_only": true
  }
}
